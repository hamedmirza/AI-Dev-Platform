APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8400
APP_API_TOKEN=change-me

DB_URL=sqlite:///./app.db

MODEL_PROVIDER=lmstudio
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen2.5-coder-14b-instruct
# Optional per-stage overrides (inherit LMSTUDIO_MODEL when blank):
# LMSTUDIO_MODEL_PLANNER=
# LMSTUDIO_MODEL_ARCHITECT=
# LMSTUDIO_MODEL_UI_DESIGNER=
# LMSTUDIO_MODEL_CODER=
# LMSTUDIO_MODEL_REVIEWER=
# LMSTUDIO_MODEL_TESTER=
# LMSTUDIO_MODEL_SUPERVISOR=
LMSTUDIO_API_KEY=lm-studio
PROVIDER_TIMEOUT_SECONDS=60
GIT_CLONE_TIMEOUT_SECONDS=300

WORKSPACE_ROOT=./workspace
BACKUP_ROOT=./backups
# Absolute path to this repository on your machine (see README "Source repository").
# Example: /Users/you/projects/AI-Dev-Platform
SOURCE_REPO_PATH=
# Comma-separated hostnames allowed for HTTPS/SSH task source_repo remotes (empty = remotes disabled).
ALLOWED_GIT_HOSTS=
# Optional comma-separated absolute directory prefixes for local task source_repo paths.
ALLOWED_SOURCE_REPO_ROOTS=
APP_ENCRYPTION_KEY=change-me
GIT_AUTHOR_NAME=AI Dev Platform
GIT_AUTHOR_EMAIL=ai-dev-platform@example.com
WORKER_COUNT=1
USE_SCOUT_STAGE=false
PLAYBOOK_SUPERVISOR_ENABLED=false
PLAYBOOK_REQUIRE_HUMAN_CONFIRM=true
PLAYBOOK_SUPERVISOR_SYSTEM_PROMPT_PATH=app/agents/prompts/playbook_supervisor.md
LOG_LEVEL=INFO
